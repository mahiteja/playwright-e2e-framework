# Copy values from this template into .env.test and .env.uat as needed.
# playwright.config.ts loads .env.<TEST_ENV> explicitly.

TEST_ENV=test
BASE_URL=https://jsonplaceholder.typicode.com

# API key auth
API_KEY=

# Basic auth
BASIC_USER=testuser
BASIC_PASS=testpass

# Bearer / JWT
BEARER_TOKEN=

# OAuth 2.0
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_TOKEN_URL=

# NTLM
NTLM_USER=
NTLM_PASS=
NTLM_URL=

# mTLS
MTLS_ORIGIN=
MTLS_CERT_PATH=certs/client.pem
MTLS_KEY_PATH=certs/client-key.pem
MTLS_CA_PATH=

# Storage state output
STORAGE_STATE_PATH=fixtures/auth/storageState.json
