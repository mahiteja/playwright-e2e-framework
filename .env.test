# ── Test environment ─────────────────────────────────────────
TEST_ENV=test
BASE_URL=https://jsonplaceholder.typicode.com

# ── API Key (header or query-param auth) ────────────────────
API_KEY=

# ── Basic Auth credentials (used by httpbin.org demos) ──────
BASIC_USER=testuser
BASIC_PASS=testpass

# ── Bearer / JWT token ────────────────────────────────────────
# Populated by CI secrets or OAuth2 flow at runtime
BEARER_TOKEN=

# ── OAuth 2.0 ─────────────────────────────────────────────────
# Client Credentials flow — fill in for your token server
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_TOKEN_URL=

# ── NTLM ─────────────────────────────────────────────────────
NTLM_USER=
NTLM_PASS=
NTLM_URL=

# ── mTLS certificate paths (relative to project root) ────────
MTLS_ORIGIN=
MTLS_CERT_PATH=certs/client.pem
MTLS_KEY_PATH=certs/client-key.pem
MTLS_CA_PATH=

# ── Storage state ─────────────────────────────────────────────
STORAGE_STATE_PATH=fixtures/auth/storageState.json
